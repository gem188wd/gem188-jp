<!DOCTYPE html>
<html lang="id">

<head>
     <meta charset="UTF-8">
     <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <title>
          <%= type==='login' ? 'Masuk' : 'Daftar' %> | Gem188
     </title>
     <script src="https://cdn.tailwindcss.com"></script>
     <script src="https://unpkg.com/lucide@latest"></script>
     <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap"
          rel="stylesheet">
     <style>
          body {
               font-family: 'Plus Jakarta Sans', sans-serif;
          }
     </style>
</head>

<body class="bg-[#f0f4f8] min-h-screen flex items-center justify-center p-6">

     <div class="w-full max-w-md animate__animated animate__fadeIn">
          <div class="text-center mb-10">
               <a href="/" class="text-4xl font-extrabold tracking-tighter inline-block mb-4">GEM<span
                         class="text-blue-600">188</span></a>
               <p class="text-gray-500 font-medium">Selamat datang di ekosistem Gem188.</p>
          </div>

          <div class="bg-white p-10 rounded-[40px] shadow-2xl shadow-blue-100 border border-gray-100">
               <h2 class="text-2xl font-bold text-gray-900 mb-8">
                    <%= type==='login' ? 'Masuk ke Akun' : 'Buat Akun Baru' %>
               </h2>

               <form class="space-y-6">
                    <% if (type==='daftar' ) { %>
                         <div class="space-y-2">
                              <label class="text-xs font-bold text-gray-400 uppercase ml-2">Nama Lengkap</label>
                              <input type="text" placeholder="Masukkan nama Anda"
                                   class="w-full p-4 rounded-2xl bg-gray-50 border border-transparent focus:border-blue-600 focus:bg-white outline-none transition font-medium">
                         </div>
                         <% } %>
                              <div class="space-y-2">
                                   <label class="text-xs font-bold text-gray-400 uppercase ml-2">Email</label>
                                   <input type="email" placeholder="email@contoh.com"
                                        class="w-full p-4 rounded-2xl bg-gray-50 border border-transparent focus:border-blue-600 focus:bg-white outline-none transition font-medium">
                              </div>
                              <div class="space-y-2">
                                   <label class="text-xs font-bold text-gray-400 uppercase ml-2">Password</label>
                                   <input type="password" placeholder="••••••••"
                                        class="w-full p-4 rounded-2xl bg-gray-50 border border-transparent focus:border-blue-600 focus:bg-white outline-none transition font-medium">
                              </div>

                              <button type="button"
                                   class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold text-lg hover:bg-blue-700 shadow-xl shadow-blue-200 transition mt-4">
                                   <%= type==='login' ? 'Masuk' : 'Daftar Sekarang' %>
                              </button>
               </form>

               <div class="mt-8 text-center text-sm">
                    <span class="text-gray-400">
                         <%= type==='login' ? 'Belum punya akun?' : 'Sudah punya akun?' %>
                    </span>
                    <a href="<%= type === 'login' ? '/daftar' : '/login' %>"
                         class="text-blue-600 font-bold hover:underline ml-1">
                         <%= type==='login' ? 'Daftar gratis' : 'Masuk di sini' %>
                    </a>
               </div>
          </div>
     </div>

     <script>lucide.createIcons();</script>
</body>

</html>