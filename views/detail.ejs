<!DOCTYPE html>
<html lang="id">

<head>
     <meta charset="UTF-8">
     <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <title>
          <%= product.name %> | Gem188
     </title>
     <script src="https://cdn.tailwindcss.com"></script>
     <script src="https://unpkg.com/lucide@latest"></script>
     <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap"
          rel="stylesheet">
     <style>
          body {
               font-family: 'Plus Jakarta Sans', sans-serif;
          }
     </style>
</head>

<body class="bg-slate-50">

     <nav class="max-w-7xl mx-auto px-6 py-8 flex items-center justify-between">
          <a href="/" class="flex items-center gap-2 text-slate-500 hover:text-blue-600 transition font-bold">
               <i data-lucide="arrow-left"></i> Kembali
          </a>
          <div class="text-2xl font-black tracking-tighter">GEM<span class="text-blue-600">188</span></div>
     </nav>

     <main class="max-w-7xl mx-auto px-6 py-12">
          <div class="grid md:grid-cols-2 gap-16">
               <div class="bg-white p-4 rounded-[40px] shadow-2xl border border-slate-100 overflow-hidden">
                    <img src="<%= product.img %>" alt="<%= product.name %>"
                         class="w-full h-[500px] object-cover rounded-[32px]">
               </div>

               <div class="flex flex-col justify-center space-y-8">
                    <div>
                         <span class="text-blue-600 font-bold text-xs uppercase tracking-widest">
                              <%= product.category %>
                         </span>
                         <h1 class="text-5xl font-extrabold text-slate-900 mt-2 leading-tight">
                              <%= product.name %>
                         </h1>
                    </div>

                    <p class="text-slate-500 text-xl leading-relaxed">
                         <%= product.desc %>
                    </p>

                    <div class="text-4xl font-black text-slate-900">
                         <%= product.price %>
                    </div>

                    <div class="flex gap-4 pt-4">
                         <button
                              class="flex-1 bg-blue-600 text-white py-5 rounded-[24px] font-bold text-lg hover:bg-blue-700 shadow-2xl shadow-blue-200 transition">Beli
                              Sekarang</button>
                         <button
                              class="w-16 h-16 rounded-[24px] border border-slate-200 flex items-center justify-center text-slate-400 hover:bg-slate-100 transition">
                              <i data-lucide="heart"></i>
                         </button>
                    </div>
               </div>
          </div>
     </main>

     <script>lucide.createIcons();</script>
</body>

</html>